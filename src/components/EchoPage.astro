---
import footerPartial from '../partials/footer.html?raw';
import { rewriteAssetPaths } from '../utils/rewriteAssetPaths';

interface Props {
  html: string;
  injectFooter?: boolean;
}

const { html, injectFooter = false } = Astro.props;

let output = rewriteAssetPaths(html);

if (injectFooter) {
  const footerStart = output.indexOf('<footer class="footer7_component">');
  const footerEnd = output.indexOf('</footer>', footerStart) + '</footer>'.length;
  if (footerStart !== -1) {
    output =
      output.slice(0, footerStart) +
      rewriteAssetPaths(footerPartial) +
      output.slice(footerEnd);
  }
}
---

<Fragment set:html={output} />
