---
import { analytics, vendor } from '../../data/site';
import { rootPath } from '../../utils/rootPath';

interface Props {
  includeFinsweet?: boolean;
}

const { includeFinsweet = false } = Astro.props;
const gaId = analytics.gaMeasurementId;
const gtmId = analytics.gtmId;
const crispId = analytics.crispWebsiteId;
const clarityId = analytics.clarityProjectId;
---

<script is:inline define:vars={{ gaId }}>
  (function (w, i, g) {
    w[g] = w[g] || [];
    if (typeof w[g].push == 'function') w[g].push.apply(w[g], Array.isArray(i) ? i : [i]);
  })(window, [gaId], 'google_tags_first_party');
</script>
<script async is:inline src={rootPath(vendor.firstPartyTag)}></script>
<script is:inline define:vars={{ gaId }}>
  window.dataLayer = window.dataLayer || [];
  function gtag() {
    dataLayer.push(arguments);
  }
  gtag('set', 'developer_id.dZGVlNj', true);
  gtag('set', 'developer_id.dYWYxNW', true);
  gtag('js', new Date());
  gtag('config', gaId);
</script>
<style is:inline>
  * {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    -o-font-smoothing: antialiased;
  }
</style>
<script is:inline define:vars={{ crispId }}>
  window.$crisp = [];
  window.CRISP_WEBSITE_ID = crispId;

  function loadCrisp() {
    if (window.__miriCrispLoaded) return;
    window.__miriCrispLoaded = true;
    const d = document;
    const s = d.createElement('script');
    s.src = 'https://client.crisp.chat/l.js';
    s.async = 1;
    d.getElementsByTagName('head')[0].appendChild(s);
  }

  window.setTimeout(loadCrisp, 3000);
  window.addEventListener('scroll', loadCrisp, { once: true, passive: true });
</script>
<meta name="facebook-domain-verification" content={analytics.facebookDomainVerification} />
<script is:inline define:vars={{ gtmId }}>
  (function (w, d, s, l, i) {
    w[l] = w[l] || [];
    w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
    const f = d.getElementsByTagName(s)[0];
    const j = d.createElement(s);
    const dl = l != 'dataLayer' ? '&l=' + l : '';
    j.async = true;
    j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
    f.parentNode.insertBefore(j, f);
  })(window, document, 'script', 'dataLayer', gtmId);
</script>
<script id="cookieyes" type="text/javascript" src={vendor.cookieYes} is:inline></script>
{includeFinsweet ? <script async src={vendor.finsweetModal} is:inline></script> : null}
<script is:inline define:vars={{ clarityId }}>
  function loadClarity() {
    if (window.__miriClarityLoaded) return;
    window.__miriClarityLoaded = true;

  (function (c, l, a, r, i, t, y) {
    c[a] = c[a] || function () {
      (c[a].q = c[a].q || []).push(arguments);
    };
    t = l.createElement(r);
    t.async = 1;
    t.src = 'https://www.clarity.ms/tag/' + i + '?ref=Webflow';
    y = l.getElementsByTagName(r)[0];
    y.parentNode.insertBefore(t, y);
  })(window, document, 'clarity', 'script', clarityId);
  }

  if ('requestIdleCallback' in window) {
    requestIdleCallback(loadClarity);
  } else {
    window.setTimeout(loadClarity, 2000);
  }
</script>
