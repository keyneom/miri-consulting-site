---
import { cta } from '../../data/site';

interface Props {
  variant?: 'nav' | 'hero' | 'hero-big' | 'contact';
  calendlyUrl?: string;
  includeStyles?: boolean;
}

const {
  variant = 'nav',
  calendlyUrl = cta.calendlyUrl,
  includeStyles = false,
} = Astro.props;

const className =
  variant === 'hero-big' ? 'calendly-widget-big' : 'calendly-widget';
---

<div class="w-embed w-script">
  {includeStyles ? (
    <style is:inline>
      {`.calendly-widget {
    background-color: #0094ff;
    color: white;
    padding: 0.5rem 1.5rem;
    text-decoration: none;
    border-radius: 2rem;
    font-weight: 600;
 }
.calendly-widget-big {
    background-color: #0094ff;
    color: white;
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    border-radius: 2rem;
    font-weight: 600;
    font-size: 1.125rem;
 }`}
    </style>
  ) : null}
  {includeStyles ? (
    <>
      <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
      <script
        src="https://assets.calendly.com/assets/external/widget.js"
        type="text/javascript"
        async
        is:inline
      />
    </>
  ) : null}
  <a
    href={calendlyUrl}
    class={className}
    onclick={`Calendly.initPopupWidget({url: '${calendlyUrl}'});return false;`}
  >
    Connect
  </a>
</div>
