---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="Page Not Found | Miri Consulting"
  description={site.description}
  canonicalPath="/404.html"
  bodyClass="body"
  webflowPageId={site.webflowHomePageId}
  robots="noindex,nofollow"
>
  <main class="main-wrapper">
    <section class="section_header1">
      <div class="padding-global">
        <div class="container-small">
          <div class="padding-section-large">
            <h1 class="heading">Page not found</h1>
            <p class="text-size-medium">The page you requested could not be found.</p>
            <a href={import.meta.env.BASE_URL} class="button w-button">Back to Home</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
